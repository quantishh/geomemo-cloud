# =============================================================================
# GeoMemo Environment Variables
# Copy this file to .env and fill in your actual values.
# =============================================================================

# --- Admin Dashboard Authentication (HTTP Basic Auth) ---
# When set, the admin dashboard shows a native browser login popup.
# Leave ADMIN_PASSWORD empty to DISABLE auth (e.g. if nginx handles it).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# --- CORS Allowed Origins ---
# Comma-separated list of domains allowed to call this API.
# Default: https://geomemo.news,http://localhost:3000,http://localhost:8000
# CORS_ORIGINS=https://geomemo.news,http://localhost:3000

# --- PostgreSQL Database ---
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# --- Groq API (LLM classification) ---
GROQ_API_KEY=

# --- Beehiiv Newsletter ---
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# --- BrightData Proxy (scraping) ---
# Option 1: Single combined URL (preferred)
BRIGHTDATA_PROXY_URL=
# Option 2: Individual parts (fallback if BRIGHTDATA_PROXY_URL not set)
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=
BRIGHTDATA_HOST=brd.superproxy.io
BRIGHTDATA_PORT=33335

# --- Social Media: Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# --- Social Media: Twitter/X (Phase 2) ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# --- BrightData WebUnlocker (full content extraction) ---
BRIGHTDATA_WEBUNLOCKER_API_KEY=
BRIGHTDATA_WEBUNLOCKER_PASSWORD=

# --- SERP API (Google News search) ---
SERPAPI_KEY=

# --- Anthropic API (Haiku summaries) ---
ANTHROPIC_API_KEY=

# --- Social Media: Drip Feed Settings (all optional, sensible defaults) ---
# Min scores for articles to be auto-posted
# DRIP_MIN_APPROVAL_SCORE=85
# DRIP_MIN_CONFIDENCE=80
# Post 1 article every 30 minutes during business hours
# DRIP_INTERVAL_MINUTES=30
# DRIP_ARTICLES_PER_CYCLE=1
# Posting window in Eastern Time (24h format)
# DRIP_START_HOUR_ET=7
# DRIP_END_HOUR_ET=22
# Look back 24 hours for eligible articles
# DRIP_LOOKBACK_HOURS=24
# Auto-post newsletter digest to Telegram when generated
# SOCIAL_AUTO_POST_NEWSLETTER=true
